{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://splat-facade-baker.dev/schemas/sfbmesh.schema.json",
  "title": "SFB Mesh JSON",
  "type": "object",
  "required": ["schema", "vertex_count", "triangle_count", "vertices", "triangles"],
  "properties": {
    "schema": { "const": "sfb.mesh.v1" },
    "vertex_count": { "type": "integer", "minimum": 0 },
    "triangle_count": { "type": "integer", "minimum": 0 },
    "vertices": {
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [{ "type": "number" }, { "type": "number" }, { "type": "number" }],
        "minItems": 3,
        "maxItems": 3
      }
    },
    "triangles": {
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [{ "type": "integer" }, { "type": "integer" }, { "type": "integer" }],
        "minItems": 3,
        "maxItems": 3
      }
    },
    "normals": {
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [{ "type": "number" }, { "type": "number" }, { "type": "number" }],
        "minItems": 3,
        "maxItems": 3
      }
    },
    "uv": {
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [{ "type": "number" }, { "type": "number" }],
        "minItems": 2,
        "maxItems": 2
      }
    },
    "bounds": {
      "type": "object",
      "properties": {
        "min": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
        "max": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
      }
    }
  }
}

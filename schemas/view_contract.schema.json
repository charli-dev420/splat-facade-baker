{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://splat-facade-baker.dev/schemas/view_contract.schema.json",
  "title": "SFB ViewContract",
  "type": "object",
  "required": [
    "schema",
    "view_contract_id",
    "camera_type",
    "views"
  ],
  "properties": {
    "schema": {
      "const": "sfb.view_contract.v1"
    },
    "view_contract_id": {
      "type": "string"
    },
    "camera_type": {
      "enum": [
        "orthographic",
        "perspective"
      ]
    },
    "unit": {
      "type": "string",
      "default": "meters"
    },
    "scale_policy": {
      "type": "string"
    },
    "object_centering": {
      "type": "string"
    },
    "views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "view_id",
          "azimuth_deg",
          "elevation_deg"
        ],
        "properties": {
          "view_id": {
            "type": "string"
          },
          "azimuth_deg": {
            "type": "number"
          },
          "elevation_deg": {
            "type": "number"
          },
          "role": {
            "type": "string"
          },
          "preferred_camera_band": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 2,
            "maxItems": 2
          },
          "bake_mode": {
            "enum": [
              "flat_card",
              "depth_card",
              "layered_card",
              "multi_angle_impostor"
            ]
          }
        }
      }
    }
  }
}
